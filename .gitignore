# Company data must never be committed.
*.xlsx
*.xls
*.numbers
*.csv
*.tsv
*.parquet
*.feather
*.jsonl
*.db
*.sqlite
*.sqlite3

# Private inputs, mappings, and generated artifacts.
datasets/
private/
runs/
artifacts/
checkpoints/
config.local.yaml
configs/local*.yaml
.env
.env.*
# Serialized models remain local.
*.cbm
*.pkl
*.pickle

# Notebook source is tracked, but executed outputs must be cleared before publishing.

